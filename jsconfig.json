{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": { "@/*": ["src/*"] },
        "checkJs": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true
    },
    "include": ["src", "eslint.config.js", "types"]
}
